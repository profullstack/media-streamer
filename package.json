{
  "name": "media-streamer",
  "version": "0.3.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepare": "git config core.hooksPath .githooks || true",
    "precommit": "pnpm build && pnpm test && pnpm lint",
    "supabase:update-emails": "tsx --env-file=.env scripts/supabase-update-emails.ts",
    "supabase:delete-torrent": "tsx --env-file=.env scripts/supabase-delete-infohash.ts",
    "enrich-metadata": "tsx --env-file=.env scripts/enrich-torrent-metadata.ts",
    "enrich-metadata:all": "tsx --env-file=.env scripts/enrich-torrent-metadata.ts --all-status",
    "enrich-metadata:dry-run": "tsx --env-file=.env scripts/enrich-torrent-metadata.ts --all-status --dry-run",
    "enrich-metadata:force": "tsx --env-file=.env scripts/enrich-torrent-metadata.ts --all-status --force",
    "enrich-folders": "tsx --env-file=.env scripts/enrich-folder-metadata.ts",
    "enrich-folders:all": "tsx --env-file=.env scripts/enrich-folder-metadata.ts --all-status",
    "enrich-folders:dry-run": "tsx --env-file=.env scripts/enrich-folder-metadata.ts --all-status --dry-run",
    "enrich-folders:force": "tsx --env-file=.env scripts/enrich-folder-metadata.ts --all-status --force",
    "iptv-worker": "tsx --env-file=.env workers/iptv-cache/index.ts",
    "iptv-worker:dev": "tsx --watch --env-file=.env workers/iptv-cache/index.ts",
    "podcast-worker": "tsx --env-file=.env workers/podcast-notifier/index.ts",
    "podcast-worker:dev": "tsx --watch --env-file=.env workers/podcast-notifier/index.ts"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@noriginmedia/norigin-spatial-navigation": "^3.0.0",
    "@profullstack/autoblog": "github:profullstack/autoblog#75e54af",
    "@profullstack/emailer": "^1.0.1",
    "@profullstack/referrals": "^0.1.0",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-scroll-area": "^1.2.11",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slider": "^1.4.0",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-toast": "^1.2.16",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@supabase/supabase-js": "~2.108.2",
    "@types/video.js": "^7.3.58",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "epubjs": "^0.3.93",
    "foliate-js": "^1.0.1",
    "framer-motion": "^12.40.0",
    "hls.js": "^1.6.16",
    "imapflow": "^1.4.0",
    "ioredis": "^5.11.1",
    "isomorphic-dompurify": "^3.17.0",
    "linkedom": "^0.18.12",
    "lucide-react": "^1.18.0",
    "mailparser": "^3.9.9",
    "mpegts.js": "^1.8.0",
    "next": "16.2.9",
    "node-datachannel": "^0.32.3",
    "openai": "^6.42.0",
    "posthog-js": "^1.386.8",
    "puppeteer": "^24.42.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-pdf": "^10.4.1",
    "resend": "^6.12.4",
    "sax": "^1.6.0",
    "tailwind-merge": "^3.6.0",
    "undici": "^7.24.4",
    "video.js": "^8.23.7",
    "web-push": "^3.6.7",
    "webtorrent": "^2.8.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "28.0.3",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sax": "^1.2.7",
    "@types/web-push": "^3.6.4",
    "@types/webtorrent": "^0.110.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@9.15.1",
  "pnpm": {
    "overrides": {
      "bittorrent-tracker>undici": "^7.16.0",
      "mpegts.js>webworkify-webpack": "2.1.5",
      "basic-ftp": "^5.2.0"
    }
  }
}
